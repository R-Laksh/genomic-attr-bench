<?xml version='1.0' encoding='UTF-8'?>
<seqgradata xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://kkrismer.github.io/seqgra/data-config.xsd">
  <general id="mc2-dna200-ab-spacing-3to5-s6-80000">
    <name>COUNT_3</name>
    <description>Positive requires 3 or more copies of A</description>
    <task>multi-class classification</task>
    <sequencespace>DNA</sequencespace>
    <seed>1</seed>
  </general>

  <background>
    <minlength>200</minlength>
    <maxlength>200</maxlength>
    <alphabetdistributions>
      <alphabetdistribution>
        <letter probability="0.25">A</letter>
        <letter probability="0.25">C</letter>
        <letter probability="0.25">G</letter>
        <letter probability="0.25">T</letter>
      </alphabetdistribution>
    </alphabetdistributions>
  </background>

  <datageneration>
    <sets>
      <set name="training">
        <example samples="80000"><conditionref cid="c1"/></example>
        <example samples="80000"><conditionref cid="c2"/></example>
      </set>
      <set name="validation">
        <example samples="10000"><conditionref cid="c1"/></example>
        <example samples="10000"><conditionref cid="c2"/></example>
      </set>
      <set name="test">
        <example samples="20000"><conditionref cid="c1"/></example>
        <example samples="20000"><conditionref cid="c2"/></example>
      </set>
    </sets>
  </datageneration>

  <conditions>
    <!-- Positive: A or B -->
    <condition id="c1">
      <label>c1</label>
      <description>Positive: A or B</description>
      <mode>mutually exclusive</mode>
      <grammar>
        <rule>
          <position>random</position>
          <probability>0.34</probability>
          <sequenceelementrefs>
            <sequenceelementref sid="seA1"/>
            <sequenceelementref sid="seA2"/>
            <sequenceelementref sid="seA3"/>
          </sequenceelementrefs>
        </rule>
        <rule>
          <position>random</position>
          <probability>0.33</probability>
          <sequenceelementrefs>
            <sequenceelementref sid="seA1"/>
            <sequenceelementref sid="seA2"/>
            <sequenceelementref sid="seA3"/>
            <sequenceelementref sid="seA4"/>
          </sequenceelementrefs>
        </rule>
        <rule>
          <position>random</position>
          <probability>0.33</probability>
          <sequenceelementrefs>
            <sequenceelementref sid="seA1"/>
            <sequenceelementref sid="seA2"/>
            <sequenceelementref sid="seA3"/>
            <sequenceelementref sid="seA4"/>
            <sequenceelementref sid="seA5"/>
          </sequenceelementrefs>
        </rule>
      </grammar>
    </condition>

    <!-- Negative: None-->
    <condition id="c2">
      <label>c2</label>
      <description>Negative: None</description>
      <grammar>
        <rule>
          <position>random</position>
          <probability>0.34</probability>
          <sequenceelementrefs>
            <sequenceelementref sid="seC"/>
          </sequenceelementrefs>
        </rule>
        <rule>
          <position>random</position>
          <probability>0.33</probability>
          <sequenceelementrefs>
            <sequenceelementref sid="seA1"/>
          </sequenceelementrefs>
        </rule>
        <rule>
          <position>random</position>
          <probability>0.34</probability>
          <sequenceelementrefs>
            <sequenceelementref sid="seA1"/>
            <sequenceelementref sid="seA2"/>
          </sequenceelementrefs>
        </rule>
      </grammar>
    </condition>
  </conditions>

  <sequenceelements>
    <sequenceelement id="seA1">
      <kmerbased>
        <kmer probability="1.0">TATAAA</kmer>
      </kmerbased>
    </sequenceelement>
    <sequenceelement id="seA2">
      <kmerbased>
        <kmer probability="1.0">TATAAA</kmer>
      </kmerbased>
    </sequenceelement>
    <sequenceelement id="seA3">
      <kmerbased>
        <kmer probability="1.0">TATAAA</kmer>
      </kmerbased>
    </sequenceelement>
    <sequenceelement id="seA4">
      <kmerbased>
        <kmer probability="1.0">TATAAA</kmer>
      </kmerbased>
    </sequenceelement>
    <sequenceelement id="seA5">
      <kmerbased>
        <kmer probability="1.0">TATAAA</kmer>
      </kmerbased>
    </sequenceelement>
    <sequenceelement id="seC">
      <matrixbased>
        <position>
          <letter probability="0.25">A</letter>
          <letter probability="0.25">C</letter>
          <letter probability="0.25">G</letter>
          <letter probability="0.25">T</letter>
        </position>
        <position>
          <letter probability="0.25">A</letter>
          <letter probability="0.25">C</letter>
          <letter probability="0.25">G</letter>
          <letter probability="0.25">T</letter>
        </position>
        <position>
          <letter probability="0.25">A</letter>
          <letter probability="0.25">C</letter>
          <letter probability="0.25">G</letter>
          <letter probability="0.25">T</letter>
        </position>
        <position>
          <letter probability="0.25">A</letter>
          <letter probability="0.25">C</letter>
          <letter probability="0.25">G</letter>
          <letter probability="0.25">T</letter>
        </position>
        <position>
          <letter probability="0.25">A</letter>
          <letter probability="0.25">C</letter>
          <letter probability="0.25">G</letter>
          <letter probability="0.25">T</letter>
        </position>
        <position>
          <letter probability="0.25">A</letter>
          <letter probability="0.25">C</letter>
          <letter probability="0.25">G</letter>
          <letter probability="0.25">T</letter>
        </position>
      </matrixbased>
    </sequenceelement>
  </sequenceelements>
</seqgradata>
